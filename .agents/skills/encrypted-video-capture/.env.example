# encrypted-video-capture — environment configuration
# Copy this file to .env and fill in values as needed.

# BlackHole audio device index (auto-detected by preflight; override if needed).
# Run: ffmpeg -f avfoundation -list_devices true -i "" 2>&1
# Look for the [N] index next to "BlackHole 2ch".
BLACKHOLE_DEVICE=

# ASR provider selection.
# Options: auto | faster-whisper | openai | off
# "auto" tries faster-whisper first, falls back to OpenAI API.
ASR_PROVIDER=auto

# OpenRouter API key — used as ASR fallback when faster-whisper is unavailable.
# Sign up at https://openrouter.ai to get a key.
OPENROUTER_API_KEY=

# OpenAI API key — alternative ASR fallback.
OPENAI_API_KEY=

# Output directory for lecture .md files.
# Default: courses/ relative to the working directory when the skill is invoked.
OUTPUT_DIR=

# Browser for yt-dlp cookie export.
# Note: only affects the yt-dlp --cookies-from-browser probe step.
# Supported values: chrome | firefox | safari | edge
# Safari cookies are not supported by yt-dlp on all platforms.
DEFAULT_BROWSER=chrome
