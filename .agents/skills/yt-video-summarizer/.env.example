# yt-video-summarizer — environment configuration
# Copy this file to .env and fill in values as needed.

# ASR provider selection.
# Options: auto | faster-whisper | openai | off
# "faster-whisper" uses the local faster-whisper library (no API key needed).
# "auto" tries faster-whisper first, falls back to OpenAI API.
ASR_PROVIDER=faster-whisper

# faster-whisper model to use for local transcription.
# Recommended: large-v3 (best accuracy); alternatives: large-v2, medium, small, tiny
FASTER_WHISPER_MODEL=large-v3

# OpenRouter API key — used as ASR fallback when faster-whisper is unavailable.
# Sign up at https://openrouter.ai to get a key.
OPENROUTER_API_KEY=

# OpenAI API key — alternative ASR fallback.
OPENAI_API_KEY=

# Browser for yt-dlp cookie export (used to bypass anti-bot checks).
# Supported values: chrome | firefox | safari | edge
DEFAULT_BROWSER=chrome

# Proxy URL auto-applied for YouTube URLs only (youtube.com / youtu.be).
# Ignored for Bilibili and other platforms. Override per-call with --proxy.
# Examples: http://10.27.7.110:8080 | socks5://127.0.0.1:1080
YT_PROXY=
